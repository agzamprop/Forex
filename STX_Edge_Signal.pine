// STX Edge — XAUUSD Signal Indicator v2.3
// Box TP/SL urilguncha cho'ziladi, keyin to'xtaydi
// 1 signal = 1 savdo (tugaguncha yangi signal yo'q)
// Faqat London + New York sessiyasida
// SL: $5 | TP: $20 | R:R = 1:4

//@version=5
indicator('STX Edge — XAUUSD Signal v2.3'
         , 'STX Edge v2.3'
         , overlay=true
         , max_boxes_count=500
         , max_lines_count=500
         , max_labels_count=500
         )

//------------------------------------------------------------------------------
// Settings
//-----------------------------------------------------------------------------{
grpTrend = 'Trend Settings'
swingLen    = input.int(10, 'Swing Length', minval=3, maxval=50, group=grpTrend)
htfTrend    = input.timeframe('5', 'Higher TF for Trend', group=grpTrend)
useHTF      = input.bool(true, 'Use Multi-Timeframe', group=grpTrend)
useEMA      = input.bool(true, 'EMA Trend Filter', group=grpTrend)
emaLen      = input.int(50, 'EMA Length', group=grpTrend)

grpSignal = 'Signal Settings'
slPips      = input.float(5.0, 'Stop Loss ($)', step=0.5, group=grpSignal)
tpPips      = input.float(20.0, 'Take Profit ($)', step=1.0, group=grpSignal)

grpSession = 'Session Settings'
londonStart = input.int(3, 'London Start (UTC)', minval=0, maxval=23, group=grpSession)
londonEnd   = input.int(12, 'London End (UTC)', minval=0, maxval=23, group=grpSession)
nyStart     = input.int(8, 'NY Start (UTC)', minval=0, maxval=23, group=grpSession)
nyEnd       = input.int(17, 'NY End (UTC)', minval=0, maxval=23, group=grpSession)

grpVisual = 'Visual Settings'
colBull     = input.color(#089981, 'Bull Color', inline='col', group=grpVisual)
colBear     = input.color(#f23645, 'Bear Color', inline='col', group=grpVisual)
colRisk     = input.color(color.new(#787b86, 70), 'Risk Zone (SL)', group=grpVisual)
colReward   = input.color(color.new(#5b9cf6, 70), 'Reward Zone (TP)', group=grpVisual)

//-----------------------------------------------------------------------------}
// Session Filter
//-----------------------------------------------------------------------------{
utcHour = hour(time, 'UTC')
bool inLondon = utcHour >= londonStart and utcHour < londonEnd
bool inNY = utcHour >= nyStart and utcHour < nyEnd
bool inSession = inLondon or inNY

//-----------------------------------------------------------------------------}
// Trend Detection
//-----------------------------------------------------------------------------{
ph = ta.pivothigh(high, swingLen, swingLen)
pl = ta.pivotlow(low, swingLen, swingLen)

var float lastPH = na
var float prevPH = na
var float lastPL = na
var float prevPL = na

if not na(ph)
    prevPH := lastPH
    lastPH := ph

if not na(pl)
    prevPL := lastPL
    lastPL := pl

var int structureTrend = 0

if not na(lastPH) and not na(prevPH) and lastPH > prevPH and not na(lastPL) and not na(prevPL) and lastPL > prevPL
    structureTrend := 1
if not na(lastPH) and not na(prevPH) and lastPH < prevPH and not na(lastPL) and not na(prevPL) and lastPL < prevPL
    structureTrend := -1

ema50 = ta.ema(close, emaLen)
emaTrend = close > ema50 ? 1 : close < ema50 ? -1 : 0

htfTrendDir = request.security(syminfo.tickerid, htfTrend, close > ta.ema(close, emaLen) ? 1 : close < ta.ema(close, emaLen) ? -1 : 0)

var int finalTrend = 0
if useHTF and useEMA
    finalTrend := htfTrendDir == 1 and emaTrend == 1 ? 1 : htfTrendDir == -1 and emaTrend == -1 ? -1 : 0
else if useHTF
    finalTrend := htfTrendDir
else if useEMA
    finalTrend := structureTrend == 1 and emaTrend == 1 ? 1 : structureTrend == -1 and emaTrend == -1 ? -1 : 0
else
    finalTrend := structureTrend

//-----------------------------------------------------------------------------}
// Pullback Detection
//-----------------------------------------------------------------------------{
bool nearEMABuy = low <= ema50 * 1.001 and low >= ema50 * 0.998
bool nearEMASell = high >= ema50 * 0.999 and high <= ema50 * 1.002

var float brokenSupport = na
var float brokenResistance = na

if not na(lastPL) and close < lastPL and not na(prevPL)
    brokenSupport := lastPL
if not na(lastPH) and close > lastPH and not na(prevPH)
    brokenResistance := lastPH

bool nearBrokenSup = not na(brokenSupport) and high >= brokenSupport * 0.999 and high <= brokenSupport * 1.002
bool nearBrokenRes = not na(brokenResistance) and low <= brokenResistance * 1.001 and low >= brokenResistance * 0.998

bool isPullbackBuy = nearEMABuy or nearBrokenRes
bool isPullbackSell = nearEMASell or nearBrokenSup

//-----------------------------------------------------------------------------}
// Rejection Candle Detection
//-----------------------------------------------------------------------------{
float bodySize = math.abs(close - open)
float upperWick = high - math.max(close, open)
float lowerWick = math.min(close, open) - low
float candleRange = high - low

bool bullPinBar = lowerWick > bodySize * 2 and lowerWick > upperWick * 2 and candleRange > 0
bool bullEngulfing = close > open and close[1] < open[1] and close > open[1] and open < close[1]
bool bearPinBar = upperWick > bodySize * 2 and upperWick > lowerWick * 2 and candleRange > 0
bool bearEngulfing = close < open and close[1] > open[1] and close < open[1] and open > close[1]

bool bullRejection = bullPinBar or bullEngulfing
bool bearRejection = bearPinBar or bearEngulfing

//-----------------------------------------------------------------------------}
// Trade State + Box Management
//-----------------------------------------------------------------------------{
var bool inTrade = false
var float tradeEntry = na
var float tradeSL = na
var float tradeTP = na
var int tradeDir = 0

// Boxes that extend until TP/SL hit
var box riskBox = na
var box rewardBox = na
var line entryLine = na

// Check TP/SL hit
bool tpHit = false
bool slHit = false

if inTrade
    if tradeDir == 1  // BUY
        tpHit := high >= tradeTP
        slHit := low <= tradeSL
    if tradeDir == -1  // SELL
        tpHit := low <= tradeTP
        slHit := high >= tradeSL
    
    // While in trade — extend box to current bar
    if not tpHit and not slHit
        box.set_right(riskBox, bar_index + 1)
        box.set_right(rewardBox, bar_index + 1)
        line.set_x2(entryLine, bar_index + 1)
    
    // TP or SL hit — stop extending, close trade
    if tpHit or slHit
        // Box stops at this bar
        box.set_right(riskBox, bar_index)
        box.set_right(rewardBox, bar_index)
        line.set_x2(entryLine, bar_index)
        
        inTrade := false
        tradeEntry := na
        tradeSL := na
        tradeTP := na
        tradeDir := 0

//-----------------------------------------------------------------------------}
// Signal Generation
//-----------------------------------------------------------------------------{
bool rawBuy = finalTrend == 1 and isPullbackBuy and bullRejection
bool rawSell = finalTrend == -1 and isPullbackSell and bearRejection

bool buySignal = rawBuy and not inTrade and inSession
bool sellSignal = rawSell and not inTrade and inSession

// Open new trade
if buySignal
    inTrade := true
    tradeEntry := close
    tradeSL := close - slPips
    tradeTP := close + tpPips
    tradeDir := 1
    
    // Create boxes (will be extended each bar)
    riskBox := box.new(bar_index, close, bar_index + 1, close - slPips,
      border_color=color.new(colBear, 85), bgcolor=colRisk)
    rewardBox := box.new(bar_index, close + tpPips, bar_index + 1, close,
      border_color=color.new(colBull, 85), bgcolor=colReward)
    entryLine := line.new(bar_index, close, bar_index + 1, close,
      color=color.new(chart.fg_color, 60), style=line.style_dashed, width=1)
    
    // BUY label
    label.new(bar_index, close - slPips,
      text='▲ BUY\n' + str.tostring(close, '#.##'),
      color=color.new(colBull, 85),
      textcolor=colBull,
      style=label.style_label_up,
      size=size.small)

if sellSignal
    inTrade := true
    tradeEntry := close
    tradeSL := close + slPips
    tradeTP := close - tpPips
    tradeDir := -1
    
    // Create boxes (will be extended each bar)
    riskBox := box.new(bar_index, close + slPips, bar_index + 1, close,
      border_color=color.new(colBear, 85), bgcolor=colRisk)
    rewardBox := box.new(bar_index, close, bar_index + 1, close - tpPips,
      border_color=color.new(colBull, 85), bgcolor=colReward)
    entryLine := line.new(bar_index, close, bar_index + 1, close,
      color=color.new(chart.fg_color, 60), style=line.style_dashed, width=1)
    
    // SELL label
    label.new(bar_index, close + slPips,
      text='▼ SELL\n' + str.tostring(close, '#.##'),
      color=color.new(colBear, 85),
      textcolor=colBear,
      style=label.style_label_down,
      size=size.small)

// TP/SL markers
if tpHit
    label.new(bar_index, tradeDir == 1 ? high : low,
      text='✓ TP',
      color=color.new(colBull, 70),
      textcolor=colBull,
      style=tradeDir == 1 ? label.style_label_down : label.style_label_up,
      size=size.tiny)

if slHit
    label.new(bar_index, tradeDir == 1 ? low : high,
      text='✗ SL',
      color=color.new(colBear, 70),
      textcolor=colBear,
      style=tradeDir == 1 ? label.style_label_up : label.style_label_down,
      size=size.tiny)

//-----------------------------------------------------------------------------}
// Plot EMA
//-----------------------------------------------------------------------------{
plot(useEMA ? ema50 : na, 'EMA 50', color=color.new(#5b9cf6, 50), linewidth=1)

//-----------------------------------------------------------------------------}
// Session Background
//-----------------------------------------------------------------------------{
bgcolor(inSession ? color.new(#5b9cf6, 97) : na)

//-----------------------------------------------------------------------------}
// Alerts
//-----------------------------------------------------------------------------{
alertcondition(buySignal, 'BUY Signal', 'STX Edge: BUY Signal on {{ticker}} at {{close}}')
alertcondition(sellSignal, 'SELL Signal', 'STX Edge: SELL Signal on {{ticker}} at {{close}}')
alertcondition(buySignal or sellSignal, 'Any Signal', 'STX Edge: Signal on {{ticker}} at {{close}}')
alertcondition(tpHit, 'TP Hit', 'STX Edge: TP hit on {{ticker}}')
alertcondition(slHit, 'SL Hit', 'STX Edge: SL hit on {{ticker}}')

//-----------------------------------------------------------------------------}
